# =========================
# Server Configuration
# =========================
PORT=3001
NODE_ENV=development   # change to "production" in prod

# =========================
# Database Configuration (Supabase pooled connection, PgBouncer)
# Get the exact string from: Supabase  Settings  Database  Connection Pooling
# =========================
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres
DB_SSL=true

# =========================
# Security / CORS
# =========================
API_KEY=<generate with: openssl rand -hex 32>
CORS_ORIGIN=http://localhost:5173,https://your-frontend-domain.com

# =========================
# Rate Limiting
# =========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =========================
# Caching (optional)
# =========================
CACHE_TTL_SECONDS=3600

# =========================
# Logging
# =========================
LOG_LEVEL=info
